{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "workers/**/*",
    "lib/**/*"
  ],
  "exclude": [
    "node_modules",
    "lib/email",
    "lib/analytics",
    "lib/typesense",
    "lib/prisma.ts"
  ]
}