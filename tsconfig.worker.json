{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
  "workers/**/*",
  "lib/mls/**/*",
  "lib/queue/**/*",
  "lib/typesense/**/*"
],
"exclude": [
  "node_modules",
  "lib/email/**/*"
]
}