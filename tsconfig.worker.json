{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "workers/**/*.ts",
    "lib/mls/**/*.ts",
    "lib/queue/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "lib/email",
    "lib/alerts",
    "lib/analytics",
    "lib/prisma.ts",
    "lib/typesense.ts"
  ]
}